# ==============================================================================
# LexGuard AI - Fresh Target GitIgnore
# ==============================================================================

# --- Core Model Weights (CRITICAL) ---
# Prevents large binary model files from blocking GitHub uploads
legal_bert_cnn.pt
*.pt
*.pth
*.bin

# --- Tokenizer & Download Caches ---
# Excludes local downloads that pull automatically at runtime
saved_tokenizer/
.cache/
huggingface/

# --- Environment & Virtual Environments ---
# Keeps local system-specific Python folders out of the repository
__pycache__/
*.py[cod]
.venv/
venv/
env/
ENV/

# --- Local Project Documents & Logs ---
# Keeps private data files and error logs local
*.pdf
*.docx
*.log
.celery/

# --- IDE & Operating System Artifacts ---
.DS_Store
Thumbs.db
.vscode/
.idea/
